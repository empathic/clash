{
  "schema_version": 4,
  "policies": [
    {
      "name": "__internal_clash__",
      "body": [
        {
          "rule": {
            "effect": "allow",
            "fs": {
              "op": { "single": "read" },
              "path": { "subpath": { "path": { "join": [{ "env": "HOME" }, { "static": "/.clash" }] } } }
            }
          }
        },
        {
          "rule": {
            "effect": "allow",
            "exec": { "bin": { "literal": "clash" }, "args": [{ "literal": "bug" }, { "any": null }] },
            "sandbox": { "inline": [{ "effect": "allow", "net": {} }] }
          }
        },
        {
          "rule": { "effect": "allow", "exec": { "bin": { "literal": "clash" }, "args": [{ "literal": "status" }, { "any": null }] } }
        },
        {
          "rule": { "effect": "allow", "exec": { "bin": { "literal": "clash" }, "args": [{ "literal": "policy" }, { "literal": "list" }, { "any": null }] } }
        },
        {
          "rule": { "effect": "allow", "exec": { "bin": { "literal": "clash" }, "args": [{ "literal": "policy" }, { "literal": "show" }, { "any": null }] } }
        },
        {
          "rule": { "effect": "allow", "exec": { "bin": { "literal": "clash" }, "args": [{ "literal": "policy" }, { "literal": "explain" }, { "any": null }] } }
        },
        {
          "rule": { "effect": "allow", "exec": { "bin": { "literal": "clash" }, "args": [{ "literal": "policy" }, { "literal": "schema" }, { "any": null }] } }
        },
        {
          "rule": { "effect": "ask", "exec": { "bin": { "literal": "clash" }, "args": [{ "literal": "policy" }, { "literal": "shell" }, { "any": null }] } }
        },
        {
          "rule": { "effect": "ask", "exec": { "bin": { "literal": "clash" }, "args": [{ "literal": "policy" }, { "literal": "setup" }] } }
        }
      ]
    }
  ]
}
