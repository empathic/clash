<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}{% if title !== site.title %} — {{ site.title }}{% endif %}</title>
  <meta name="description" content="{{ description or site.description }}">
  <script>
    (function(){var t=localStorage.getItem("theme");if(t)document.documentElement.setAttribute("data-theme",t)})();
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ version.pathPrefix }}/css/style.css">
</head>
<body>
  <nav class="nav" role="navigation" aria-label="Main">
    <div class="nav-inner">
      <a href="{{ version.pathPrefix }}/" class="nav-wordmark">clash</a>
      <div class="nav-links">
        <a href="{{ version.pathPrefix }}/quick-start/"{% if page.url === "/quick-start/" %} aria-current="page"{% endif %}>Quick Start</a>
        <div class="nav-overflow">
          <a href="{{ version.pathPrefix }}/tutorial/"{% if page.url === "/tutorial/" %} aria-current="page"{% endif %}>Tutorial</a>
          <a href="{{ version.pathPrefix }}/reference/"{% if page.url === "/reference/" %} aria-current="page"{% endif %}>Reference</a>
          {% if version.all.length > 0 %}
          <div class="version-selector">
            <button class="version-btn" aria-haspopup="listbox" aria-expanded="false">
              {{ version.current }}
              <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <ul class="version-menu" role="listbox">
              {% for v in version.all %}
              <li role="option"{% if v === version.current %} aria-selected="true"{% endif %}>
                <a href="{% if v === version.latest %}/{% elif v === 'main' %}/main/{% else %}/{{ v }}/{% endif %}">
                  {{ v }}{% if v === version.latest %} <span class="version-badge">latest</span>{% endif %}
                </a>
              </li>
              {% endfor %}
            </ul>
          </div>
          {% endif %}
        </div>
        <a href="{{ version.pathPrefix }}/faq/"{% if page.url === "/faq/" %} aria-current="page"{% endif %}>FAQ</a>
        <a href="{{ site.repo }}" class="nav-github" aria-label="GitHub">
          <svg width="20" height="20" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
        </a>
        <button class="theme-toggle" aria-label="Toggle theme" title="Toggle theme"><svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1a7 7 0 100 14A7 7 0 008 1zM2 8a6 6 0 016-6v12a6 6 0 01-6-6z"/></svg></button>
        <button class="nav-hamburger" aria-label="Menu" aria-expanded="false">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
            <line x1="3" y1="5" x2="17" y2="5"/>
            <line x1="3" y1="10" x2="17" y2="10"/>
            <line x1="3" y1="15" x2="17" y2="15"/>
          </svg>
        </button>
      </div>
    </div>
  </nav>

  {% if version.current === "main" and version.latest !== "main" %}
  <div class="version-banner">
    You are viewing the <strong>development</strong> version.
    <a href="/">Switch to {{ version.latest }} (latest release)</a>.
  </div>
  {% elif not version.isLatest and version.current !== "main" %}
  <div class="version-banner">
    You are viewing <strong>{{ version.current }}</strong>.
    <a href="/">Switch to {{ version.latest }} (latest release)</a>.
  </div>
  {% endif %}

  <main>
    {{ content | safe }}
  </main>

  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-links">
        <a href="{{ site.repo }}">GitHub</a>
        <a href="https://crates.io/crates/clash">crates.io</a>
        <a href="https://docs.rs/clash">docs.rs</a>
      </div>
      <p class="footer-copy">&copy; 2025-2026 <a href="https://empathic.dev">Empathic</a></p>
    </div>
  </footer>

  <script src="{{ version.pathPrefix }}/js/main.js"></script>
</body>
</html>
